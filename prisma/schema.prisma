// StockLot ERP — data model (Foundation & Master Data plan).
// Dev provider: SQLite. Production target: PostgreSQL (swap provider + migrate).
// Enums are modeled as validated String columns (see src/lib/enums.ts) for SQLite/Postgres portability.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (app runtime)
  directUrl = env("DIRECT_URL") // non-pooled (migrations)
}

model CompanySettings {
  id          String   @id @default("singleton")
  name        String   @default("StockLot ERP")
  address     String?
  phone       String?
  email       String?
  tinBin      String? // TIN / BIN
  footerNote  String?
  updatedById String?
  updatedAt   DateTime @updatedAt
}

model AppUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String // OWNER|PARTNER|SALES|INVENTORY|ACCOUNTANT|ADMIN
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductStyle {
  id             String       @id @default(cuid())
  styleCode      String       @unique
  styleName      String
  genderAgeGroup String? // Mens|Ladies|Boys|Girls|Kids|Unisex
  category       String?
  seasonFlag     String? // Winter|Summer|All
  grade          String? // A|B-Grade|C-Grade|Mixed
  isBulkLot      Boolean      @default(false)
  standardCost   Decimal      @default(0)
  reorderLevel   Int          @default(0)
  active         Boolean      @default(true)
  aliases        StyleAlias[]
  saleLines      SaleLine[]
  receiptLines   ReceiptLine[]
  returnLines    ReturnLine[]
  adjustments    StockAdjustment[]
  purchaseReturnLines PurchaseReturnLine[]
  createdById    String?
  updatedById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([styleName])
}

model StyleAlias {
  id        String       @id @default(cuid())
  aliasText String       @unique
  styleId   String
  style     ProductStyle @relation(fields: [styleId], references: [id], onDelete: Cascade)
}

model Customer {
  id                String    @id @default(cuid())
  name              String
  phone             String?
  defaultLocationId String?
  location          Location? @relation(fields: [defaultLocationId], references: [id])
  creditTerms       String?
  openingDueBalance Decimal   @default(0)
  active            Boolean   @default(true)
  challans          SalesChallan[]
  receivables       ReceivableEntry[]
  createdById       String?
  updatedById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([name])
}

model Supplier {
  id                    String            @id @default(cuid())
  name                  String
  contactPhone          String?
  address               String?
  notes                 String?
  active                Boolean           @default(true)
  openingPayableBalance Decimal           @default(0)
  receipts              PurchaseReceipt[]
  payments              SupplierPayment[]
  purchaseReturns       PurchaseReturn[]
  createdById           String?
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
}

model Location {
  id           String         @id @default(cuid())
  areaName     String
  marketOrShop String?
  customers    Customer[]
  challans     SalesChallan[]
  createdById  String?
  updatedById  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditLog {
  id       String   @id @default(cuid())
  userId   String?
  entity   String
  entityId String
  action   String // CREATE|UPDATE|DELETE
  field    String?
  oldValue String?
  newValue String?
  at       DateTime @default(now())

  @@index([entity, entityId])
  @@index([at])
}

model SalesChallan {
  id          String           @id @default(cuid())
  challanNo   String?
  saleDate    DateTime
  periodMonth String // "YYYY-MM" grouping key
  customerId  String
  customer    Customer         @relation(fields: [customerId], references: [id])
  locationId  String?
  location    Location?        @relation(fields: [locationId], references: [id])
  status      String // DRAFT|DISPATCHED|PARTIALLY_PAID|PAID|VOID
  remarks     String?
  lines       SaleLine[]
  payments    PaymentReceipt[]
  returns     SalesReturn[]
  createdById String?
  updatedById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([periodMonth])
  @@index([saleDate])
  @@index([customerId])
}

model SaleLine {
  id               String       @id @default(cuid())
  challanId        String
  challan          SalesChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  styleId          String
  style            ProductStyle @relation(fields: [styleId], references: [id])
  quantity         Int
  unitPrice        Decimal
  unitCostSnapshot Decimal
  lineAmount       Decimal
  lineGrossProfit  Decimal

  @@index([challanId])
  @@index([styleId])
}

model PaymentReceipt {
  id               String       @id @default(cuid())
  challanId        String
  challan          SalesChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  receiptDate      DateTime
  amountCollected  Decimal
  discountOrWaiver Decimal      @default(0)
  method           String // cash|bank|bKash|Nagad|account
  notes            String?
  collectedById    String?
  createdAt        DateTime     @default(now())

  @@index([challanId])
}

model ReceivableEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  challanId  String?
  entryType  String // INVOICE|PAYMENT|WAIVER|OPENING|RETURN|VOID
  amount     Decimal // signed: invoice +, payment/waiver/return/void -
  entryDate  DateTime
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([challanId])
}

model SalesReturn {
  id          String       @id @default(cuid())
  challanId   String
  challan     SalesChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  returnDate  DateTime
  periodMonth String
  reason      String?
  lines       ReturnLine[]
  createdById String?
  createdAt   DateTime     @default(now())

  @@index([challanId])
  @@index([periodMonth])
}

model ReturnLine {
  id         String       @id @default(cuid())
  returnId   String
  return     SalesReturn  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  styleId    String
  style      ProductStyle @relation(fields: [styleId], references: [id])
  quantity   Int
  unitPrice  Decimal
  lineAmount Decimal

  @@index([returnId])
  @@index([styleId])
}

model SupplierPayment {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  paymentDate DateTime
  periodMonth String
  amount      Decimal
  method      String // cash|bank|bKash|Nagad|account
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([supplierId])
  @@index([periodMonth])
}

model Period {
  id          String   @id @default(cuid())
  month       String   @unique // "YYYY-MM"
  status      String   @default("OPEN") // OPEN|CLOSED
  closedAt    DateTime?
  closedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StockAdjustment {
  id             String       @id @default(cuid())
  styleId        String
  style          ProductStyle @relation(fields: [styleId], references: [id])
  adjustmentDate DateTime
  periodMonth    String
  quantity       Int // signed: positive adds stock, negative removes
  reason         String // COUNT|DAMAGE|LOSS|FOUND|OTHER
  note           String?
  createdById    String?
  createdAt      DateTime     @default(now())

  @@index([styleId])
  @@index([periodMonth])
}

model PurchaseReturn {
  id           String               @id @default(cuid())
  supplierId   String
  supplier     Supplier             @relation(fields: [supplierId], references: [id])
  returnDate   DateTime
  periodMonth  String
  reason       String?
  creditAmount Decimal              @default(0) // reduces the payable to the supplier
  lines        PurchaseReturnLine[]
  createdById  String?
  createdAt    DateTime             @default(now())

  @@index([supplierId])
  @@index([periodMonth])
}

model PurchaseReturnLine {
  id               String         @id @default(cuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  styleId          String
  style            ProductStyle   @relation(fields: [styleId], references: [id])
  quantity         Int
  unitCost         Decimal        @default(0)
  lineAmount       Decimal        @default(0)

  @@index([purchaseReturnId])
  @@index([styleId])
}

model PurchaseReceipt {
  id             String        @id @default(cuid())
  challanNo      String? // supplier delivery note (e.g. 25589)
  receiptDate    DateTime
  periodMonth    String // "YYYY-MM"
  supplierId     String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  isOpeningStock Boolean       @default(false)
  billAmount     Decimal       @default(0) // what is owed to the supplier for this lot
  remarks        String?
  lines          ReceiptLine[]
  createdById    String?
  updatedById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([periodMonth])
  @@index([receiptDate])
}

model ReceiptLine {
  id              String          @id @default(cuid())
  receiptId       String
  receipt         PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  styleId         String
  style           ProductStyle    @relation(fields: [styleId], references: [id])
  quantity        Int
  subCategoryNote String?

  @@index([receiptId])
  @@index([styleId])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0)
  expenses  Expense[]
}

model Expense {
  id            String          @id @default(cuid())
  expenseDate   DateTime
  periodMonth   String // "YYYY-MM"
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  payeeOrVendor String?
  detail        String?
  amount        Decimal // billed
  paidAmount    Decimal         @default(0) // actually paid
  isAdvance     Boolean         @default(false) // advances kept out of period operating expense
  authorizedBy  String?
  remarks       String?
  createdById   String?
  updatedById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([periodMonth])
  @@index([categoryId])
  @@index([expenseDate])
}

model Partner {
  id                    String            @id @default(cuid())
  name                  String            @unique
  openingCapitalBalance Decimal           @default(0)
  capitalMovements      CapitalMovement[]
  deposits              TreasuryDeposit[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model CapitalMovement {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id])
  periodMonth  String
  movementType String // INVESTMENT|WITHDRAWAL|SETTLEMENT
  amount       Decimal // signed by convention: investment +, withdrawal -
  date         DateTime
  notes        String?
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([partnerId])
  @@index([periodMonth])
}

model TreasuryDeposit {
  id             String   @id @default(cuid())
  periodMonth    String
  depositDate    DateTime
  payerPartnerId String?
  payer          Partner? @relation(fields: [payerPartnerId], references: [id])
  amount         Decimal
  method         String // cash|bank|account
  destination    String   @default("Alib")
  otherIncome    Decimal  @default(0)
  remarks        String?
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([periodMonth])
}
